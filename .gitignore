#################################################
# Terraform
#################################################

# Local .terraform directories
**/.terraform/*
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
plan.out

# Terraform lock file (optional)
# Keep if working in a team
# .terraform.lock.hcl

